# Application Configuration
APP_NAME=NLP-to-SQL Analytics
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# AWS Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1
BEDROCK_MAX_TOKENS=2000
BEDROCK_TEMPERATURE=0.1

# Amazon OpenSearch
OPENSEARCH_HOST=your-opensearch-domain.us-east-1.es.amazonaws.com
OPENSEARCH_PORT=443
OPENSEARCH_INDEX_NAME=query_templates
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=your_password_here
OPENSEARCH_USE_SSL=true

# Amazon Athena
ATHENA_DATABASE=apple_analytics
ATHENA_WORKGROUP=primary
ATHENA_OUTPUT_LOCATION=s3://your-bucket/athena-results/
ATHENA_MAX_EXECUTION_TIME=300
ATHENA_QUERY_TIMEOUT=60

# AWS Glue
GLUE_DATABASE=apple_analytics

# AWS Lake Formation
LAKE_FORMATION_ENABLED=false

# S3
S3_DATA_BUCKET=apple-analytics-data
S3_TEMPLATE_BUCKET=apple-analytics-templates

# Redis (ElastiCache)
REDIS_HOST=your-redis-cluster.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_TTL=3600
REDIS_ENABLED=false

# AWS Cognito
COGNITO_USER_POOL_ID=your_user_pool_id
COGNITO_CLIENT_ID=your_client_id
COGNITO_REGION=us-east-1

# Query Governance
MAX_QUERY_ROWS=10000
MAX_QUERY_RUNTIME_SECONDS=300
MAX_QUERY_COST_USD=10.0

# Mock Mode (for local testing)
MOCK_MODE=true
MOCK_DATA_PATH=data/mock/apple_sales_fact.csv
